{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 4,
    "minor": 2,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "vs2026-debug",
      "displayName": "Visual Studio 2026 Debug",
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/vs2026-debug",
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release"
      }
    },
    {
      "name": "vs2026-cuda-sm120",
      "displayName": "Visual Studio 2026 CUDA kernels sm_120",
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/vs2026-cuda-sm120",
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release",
        "PRISMINFER_ENABLE_CUDA_KERNELS": "ON",
        "PRISMINFER_CUDA_KERNEL_ARCHS": "120"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "vs2026-debug",
      "configurePreset": "vs2026-debug",
      "configuration": "Debug"
    },
    {
      "name": "vs2026-cuda-sm120",
      "configurePreset": "vs2026-cuda-sm120",
      "configuration": "Debug",
      "targets": [
        "prisminfer_cuda_kernels"
      ]
    }
  ],
  "testPresets": [
    {
      "name": "vs2026-debug",
      "configurePreset": "vs2026-debug",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
