{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prisminfer.local/schemas/telemetry.schema.json",
  "title": "PrismInfer telemetry event",
  "type": "object",
  "required": [
    "schema_version",
    "timestamp_ns",
    "run_id",
    "event",
    "mode",
    "hard_cap_bytes",
    "model_parameter_bucket",
    "parameter_count",
    "vram_tier_gib",
    "validation_cell_id",
    "validation_cell_status"
  ],
  "properties": {
    "schema_version": { "const": "0.5" },
    "timestamp_ns": { "type": "integer", "minimum": 0 },
    "run_id": { "type": "string", "minLength": 1 },
    "event": { "type": "string", "minLength": 1 },
    "mode": {
      "type": "string",
      "enum": ["1gb-safe-cpu", "1gb-safe-gpu-probed"]
    },
    "hard_cap_bytes": {
      "type": "integer",
      "minimum": 1,
      "maximum": 17179869184
    },
    "model_parameter_bucket": { "type": "string" },
    "parameter_count": { "type": "integer", "minimum": 0 },
    "vram_tier_gib": {
      "type": "integer",
      "enum": [1, 2, 4, 6, 8, 12, 16]
    },
    "validation_cell_id": { "type": "string" },
    "validation_cell_status": {
      "type": "string",
      "enum": [
        "not-started",
        "metadata-only",
        "warmup",
        "decode-smoke",
        "quality-gated",
        "profitable",
        "validated",
        "rejected"
      ]
    },
    "backend": {
      "type": "string",
      "enum": ["null", "fake", "llama"]
    },
    "backend_required": { "type": "boolean" },
    "dependency_pin_file": { "type": "string" },
    "llama_executable": { "type": "string" },
    "context_tokens": { "type": "integer", "minimum": 1 },
    "gpu_layers": { "type": "integer", "minimum": 0 },
    "mmap_enabled": { "type": "boolean" },
    "warmup_tokens": { "type": "integer", "minimum": 1 },
    "kv_accounting": { "type": "boolean" },
    "kv_placement": {
      "type": "string",
      "enum": ["backend", "gpu", "host", "mixed"]
    },
    "kv_compression": {
      "type": "string",
      "enum": ["none", "accounting-only", "reference", "experimental"]
    },
    "quality_gate": {
      "type": "string",
      "enum": ["none", "smoke", "retrieval", "long-context"]
    },
    "profitability_policy": {
      "type": "string",
      "enum": ["off", "warn", "fail-closed"]
    },
    "offload_policy": {
      "type": "string",
      "enum": ["none", "gpu", "host-kv", "nvme-simulated", "nvme-experimental"]
    },
    "claim_label": {
      "type": "string",
      "enum": [
        "metadata-only",
        "simulated",
        "measured-offload",
        "validated-benchmark",
        "deployable-profile",
        "rejected"
      ]
    },
    "claim_validation": {
      "type": "string",
      "enum": ["off", "warn", "fail-closed"]
    },
    "layer_count": { "type": "string" },
    "kv_head_count": { "type": "string" },
    "head_dim": { "type": "string" },
    "block_tokens": { "type": "string" },
    "key_bits": { "type": "string" },
    "value_bits": { "type": "string" },
    "bytes_per_token": { "type": "string" },
    "bytes_per_block": { "type": "string" },
    "logical_tokens": { "type": "string" },
    "active_blocks": { "type": "string" },
    "gpu_bytes": { "type": "string" },
    "host_bytes": { "type": "string" },
    "compressed_bytes": { "type": "string" },
    "metadata_bytes": { "type": "string" },
    "unknown_bytes": { "type": "string" },
    "compression_status": { "type": "string" },
    "compression_accepted": { "type": "string" },
    "compression_failure_reason": { "type": "string" },
    "kv_saved_bytes": { "type": "string" },
    "h2d_bytes": { "type": "string" },
    "d2h_bytes": { "type": "string" },
    "nvme_read_bytes": { "type": "string" },
    "nvme_write_bytes": { "type": "string" },
    "h2d_ms": { "type": "string" },
    "d2h_ms": { "type": "string" },
    "io_ms": { "type": "string" },
    "wait_ms": { "type": "string" },
    "prefill_ms": { "type": "string" },
    "decode_ms": { "type": "string" },
    "speedup_ratio": { "type": "string" },
    "required_speedup_ratio": { "type": "string" },
    "backend_owned_peak_bytes": { "type": "integer", "minimum": 0 },
    "backend_external_peak_bytes": { "type": "integer", "minimum": 0 },
    "evidence_status": { "type": "string" },
    "status": { "type": "string" },
    "failure_reason": { "type": "string" },
    "skipped": { "type": "string" },
    "valid": { "type": "string" },
    "model_path": { "type": "string" },
    "sidecar_path": { "type": "string" },
    "model_size_bytes": { "type": "string" },
    "sidecar_size_bytes": { "type": "string" },
    "model_sha256": { "type": "string" },
    "allocator_bytes": { "type": "integer", "minimum": 0 },
    "allocator_peak_bytes": { "type": "integer", "minimum": 0 },
    "process_gpu_bytes": { "type": "integer", "minimum": 0 },
    "process_gpu_peak_bytes": { "type": "integer", "minimum": 0 },
    "device_used_bytes": { "type": "integer", "minimum": 0 },
    "device_delta_bytes": { "type": "integer", "minimum": 0 },
    "warmup_peak_bytes": { "type": "integer", "minimum": 0 },
    "retained_pool_bytes": { "type": "integer", "minimum": 0 },
    "kv_gpu_peak_bytes": { "type": "integer", "minimum": 0 },
    "kv_host_peak_bytes": { "type": "integer", "minimum": 0 },
    "kv_compressed_peak_bytes": { "type": "integer", "minimum": 0 },
    "kv_metadata_peak_bytes": { "type": "integer", "minimum": 0 },
    "kv_unknown_peak_bytes": { "type": "integer", "minimum": 0 },
    "unknown_post_warmup_bytes": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": true
}
