{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prisminfer.local/schemas/telemetry.schema.json",
  "title": "PrismInfer telemetry event",
  "type": "object",
  "required": [
    "schema_version",
    "timestamp_ns",
    "run_id",
    "event",
    "mode",
    "hard_cap_bytes",
    "model_parameter_bucket",
    "parameter_count",
    "vram_tier_gib",
    "validation_cell_id",
    "validation_cell_status"
  ],
  "properties": {
    "schema_version": { "const": "0.2" },
    "timestamp_ns": { "type": "integer", "minimum": 0 },
    "run_id": { "type": "string", "minLength": 1 },
    "event": { "type": "string", "minLength": 1 },
    "mode": {
      "type": "string",
      "enum": ["1gb-safe-cpu", "1gb-safe-gpu-probed"]
    },
    "hard_cap_bytes": {
      "type": "integer",
      "minimum": 1,
      "maximum": 17179869184
    },
    "model_parameter_bucket": { "type": "string" },
    "parameter_count": { "type": "integer", "minimum": 0 },
    "vram_tier_gib": {
      "type": "integer",
      "enum": [1, 2, 4, 6, 8, 12, 16]
    },
    "validation_cell_id": { "type": "string" },
    "validation_cell_status": {
      "type": "string",
      "enum": [
        "not-started",
        "metadata-only",
        "warmup",
        "decode-smoke",
        "rejected"
      ]
    },
    "backend": {
      "type": "string",
      "enum": ["null", "fake", "llama"]
    },
    "backend_required": { "type": "boolean" },
    "dependency_pin_file": { "type": "string" },
    "context_tokens": { "type": "integer", "minimum": 1 },
    "gpu_layers": { "type": "integer", "minimum": 0 },
    "mmap_enabled": { "type": "boolean" },
    "warmup_tokens": { "type": "integer", "minimum": 1 },
    "backend_owned_peak_bytes": { "type": "integer", "minimum": 0 },
    "backend_external_peak_bytes": { "type": "integer", "minimum": 0 },
    "evidence_status": { "type": "string" },
    "status": { "type": "string" },
    "failure_reason": { "type": "string" },
    "skipped": { "type": "string" },
    "valid": { "type": "string" },
    "model_path": { "type": "string" },
    "sidecar_path": { "type": "string" },
    "model_size_bytes": { "type": "string" },
    "sidecar_size_bytes": { "type": "string" },
    "model_sha256": { "type": "string" },
    "allocator_bytes": { "type": "integer", "minimum": 0 },
    "allocator_peak_bytes": { "type": "integer", "minimum": 0 },
    "process_gpu_bytes": { "type": "integer", "minimum": 0 },
    "process_gpu_peak_bytes": { "type": "integer", "minimum": 0 },
    "device_used_bytes": { "type": "integer", "minimum": 0 },
    "device_delta_bytes": { "type": "integer", "minimum": 0 },
    "warmup_peak_bytes": { "type": "integer", "minimum": 0 },
    "retained_pool_bytes": { "type": "integer", "minimum": 0 },
    "unknown_post_warmup_bytes": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": true
}
