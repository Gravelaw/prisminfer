{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prisminfer.local/schemas/benchmark_manifest.schema.json",
  "title": "PrismInfer benchmark manifest",
  "type": "object",
  "required": [
    "manifest_version",
    "run_id",
    "created_at_utc",
    "tool",
    "mode",
    "hard_cap_bytes",
    "model_parameter_bucket",
    "parameter_count",
    "vram_tier_gib",
    "validation_cell_id",
    "validation_cell_status",
    "telemetry_path",
    "status"
  ],
  "properties": {
    "manifest_version": { "const": "0.3" },
    "run_id": { "type": "string", "minLength": 1 },
    "created_at_utc": { "type": "string", "minLength": 1 },
    "tool": { "type": "string", "minLength": 1 },
    "prisminfer_version": { "type": "string" },
    "cmake_version": { "type": "string" },
    "build_config": { "type": "string" },
    "compiler": { "type": "string" },
    "os": { "type": "string" },
    "cuda_probe_compiled": { "type": "boolean" },
    "mode": {
      "type": "string",
      "enum": ["1gb-safe-cpu", "1gb-safe-gpu-probed"]
    },
    "hard_cap_bytes": {
      "type": "integer",
      "minimum": 1,
      "maximum": 17179869184
    },
    "model_parameter_bucket": { "type": "string" },
    "parameter_count": { "type": "integer", "minimum": 0 },
    "vram_tier_gib": {
      "type": "integer",
      "enum": [1, 2, 4, 6, 8, 12, 16]
    },
    "validation_cell_id": { "type": "string" },
    "validation_cell_status": {
      "type": "string",
      "enum": [
        "not-started",
        "metadata-only",
        "warmup",
        "decode-smoke",
        "rejected"
      ]
    },
    "backend": {
      "type": "string",
      "enum": ["null", "fake", "llama"]
    },
    "backend_adapter_contract_version": { "type": "string" },
    "backend_required": { "type": "boolean" },
    "dependency_pin_file": { "type": "string" },
    "llama_executable": { "type": "string" },
    "context_tokens": { "type": "integer", "minimum": 1 },
    "gpu_layers": { "type": "integer", "minimum": 0 },
    "mmap_enabled": { "type": "boolean" },
    "warmup_tokens": { "type": "integer", "minimum": 1 },
    "kv_accounting": { "type": "boolean" },
    "kv_layer_count": { "type": "integer", "minimum": 0 },
    "kv_head_count": { "type": "integer", "minimum": 0 },
    "kv_head_dim": { "type": "integer", "minimum": 0 },
    "kv_block_tokens": { "type": "integer", "minimum": 0 },
    "kv_key_bits": { "type": "integer", "minimum": 0 },
    "kv_value_bits": { "type": "integer", "minimum": 0 },
    "kv_bytes_per_token": { "type": "integer", "minimum": 0 },
    "kv_bytes_per_block": { "type": "integer", "minimum": 0 },
    "kv_placement": {
      "type": "string",
      "enum": ["backend", "gpu", "host", "mixed"]
    },
    "kv_compression": {
      "type": "string",
      "enum": ["none", "accounting-only", "reference", "experimental"]
    },
    "kv_logical_tokens": { "type": "integer", "minimum": 0 },
    "kv_active_blocks": { "type": "integer", "minimum": 0 },
    "kv_gpu_bytes": { "type": "integer", "minimum": 0 },
    "kv_host_bytes": { "type": "integer", "minimum": 0 },
    "kv_compressed_bytes": { "type": "integer", "minimum": 0 },
    "kv_metadata_bytes": { "type": "integer", "minimum": 0 },
    "kv_unknown_bytes": { "type": "integer", "minimum": 0 },
    "kv_evidence_status": { "type": "string" },
    "kv_metadata_budget_bytes": { "type": "integer", "minimum": 0 },
    "quality_gate": {
      "type": "string",
      "enum": ["none", "smoke", "retrieval", "long-context"]
    },
    "quality_baseline_manifest": { "type": "string" },
    "quality_status": { "type": "string" },
    "quality_passed": { "type": "boolean" },
    "quality_failure_reason": { "type": "string" },
    "quality_observed_delta": { "type": "number" },
    "kv_compression_status": { "type": "string" },
    "kv_compression_accepted": { "type": "boolean" },
    "kv_compression_failure_reason": { "type": "string" },
    "kv_saved_bytes": { "type": "integer", "minimum": 0 },
    "retained_pool_bytes": { "type": "integer", "minimum": 0 },
    "kv_gpu_peak_bytes": { "type": "integer", "minimum": 0 },
    "kv_host_peak_bytes": { "type": "integer", "minimum": 0 },
    "kv_compressed_peak_bytes": { "type": "integer", "minimum": 0 },
    "kv_metadata_peak_bytes": { "type": "integer", "minimum": 0 },
    "kv_unknown_peak_bytes": { "type": "integer", "minimum": 0 },
    "telemetry_path": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["ok", "failed_closed"] },
    "failure_reason": { "type": "string" },
    "gpu_name": { "type": "string" },
    "cuda_driver_version": { "type": "integer", "minimum": 0 },
    "cuda_runtime_version": { "type": "integer", "minimum": 0 },
    "device_total_bytes": { "type": "integer", "minimum": 0 },
    "device_used_bytes": { "type": "integer", "minimum": 0 },
    "device_delta_bytes": { "type": "integer", "minimum": 0 },
    "allocator_peak_bytes": { "type": "integer", "minimum": 0 },
    "process_gpu_peak_bytes": { "type": "integer", "minimum": 0 },
    "warmup_peak_bytes": { "type": "integer", "minimum": 0 },
    "unknown_post_warmup_bytes": { "type": "integer", "minimum": 0 },
    "host_telemetry_available": { "type": "boolean" },
    "host_telemetry_unavailable_reason": { "type": "string" },
    "process_working_set_bytes": { "type": "integer", "minimum": 0 },
    "process_private_bytes": { "type": "integer", "minimum": 0 },
    "system_memory_available_bytes": { "type": "integer", "minimum": 0 },
    "system_commit_total_bytes": { "type": "integer", "minimum": 0 },
    "system_commit_limit_bytes": { "type": "integer", "minimum": 0 },
    "process_io_read_bytes": { "type": "integer", "minimum": 0 },
    "process_io_write_bytes": { "type": "integer", "minimum": 0 },
    "required_telemetry_present": { "type": "boolean" },
    "telemetry_agreement": { "type": "boolean" }
  },
  "additionalProperties": true
}
