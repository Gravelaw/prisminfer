{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prisminfer.local/schemas/benchmark_manifest.schema.json",
  "title": "PrismInfer benchmark manifest",
  "type": "object",
  "required": [
    "manifest_version",
    "run_id",
    "created_at_utc",
    "tool",
    "mode",
    "hard_cap_bytes",
    "model_parameter_bucket",
    "parameter_count",
    "vram_tier_gib",
    "validation_cell_id",
    "validation_cell_status",
    "telemetry_path",
    "status"
