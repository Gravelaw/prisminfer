{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prisminfer.local/schemas/kernel_benchmark_manifest.schema.json",
  "title": "PrismInfer kernel benchmark manifest",
  "type": "object",
  "required": [
    "manifest_version",
    "validation_cell_id",
    "model_hash",
    "quantization_format",
    "quant_artifact_sha256",
    "context_tokens",
    "batch_size",
    "prompt_fixture_hash",
    "backend",
    "os",
    "gpu_name",
    "driver_mode",
    "cuda_driver_version",
    "cuda_runtime_version",
    "vram_tier_gib",
    "hard_cap_bytes",
    "op_type",
    "sequence_phase",
    "kernel_backend",
    "kernel_name",
    "kernel_version",
    "baseline_backend",
    "baseline_manifest_hash",
    "correctness_fixture_hash",
    "quality_fixture_hash",
    "full_dequant_materialized",
    "workspace_peak_bytes",
    "speedup_ratio",
    "compression_status",
    "quality_gate_id",
    "cap_certification_status",
    "claim_status"
  ],
  "properties": {
    "manifest_version": { "const": "0.1" },
    "validation_cell_id": { "type": "string", "minLength": 1 },
    "model_hash": { "type": "string", "minLength": 1 },
    "quantization_format": { "type": "string", "minLength": 1 },
    "quant_artifact_sha256": { "type": "string", "minLength": 1 },
    "context_tokens": { "type": "integer", "minimum": 1 },
    "batch_size": { "type": "integer", "minimum": 1 },
    "prompt_fixture_hash": { "type": "string", "minLength": 1 },
    "backend": { "type": "string", "minLength": 1 },
    "os": { "type": "string", "minLength": 1 },
    "gpu_name": { "type": "string", "minLength": 1 },
    "driver_mode": {
      "type": "string",
      "enum": ["wddm", "tcc", "linux", "unavailable"]
    },
    "tdr_status": {
      "type": "string",
      "enum": ["enabled", "disabled", "unavailable"]
    },
    "application_control_status": {
      "type": "string",
      "enum": ["allowed", "blocked", "unavailable"]
    },
    "cuda_driver_version": { "type": "integer", "minimum": 0 },
    "cuda_runtime_version": { "type": "integer", "minimum": 0 },
    "vram_tier_gib": { "type": "integer", "enum": [4, 6, 8, 12, 16] },
    "hard_cap_bytes": {
      "type": "integer",
      "minimum": 1,
      "maximum": 17179869184
    },
    "op_type": { "type": "string", "enum": ["matmul"] },
    "sequence_phase": { "type": "string", "enum": ["decode", "prefill"] },
    "kernel_backend": { "type": "string", "minLength": 1 },
    "kernel_name": { "type": "string", "minLength": 1 },
    "kernel_version": { "type": "string", "minLength": 1 },
    "baseline_backend": { "type": "string", "minLength": 1 },
    "baseline_manifest_hash": { "type": "string", "minLength": 1 },
    "correctness_fixture_hash": { "type": "string", "minLength": 1 },
    "quality_fixture_hash": { "type": "string", "minLength": 1 },
    "dequant_fused": { "type": "boolean" },
    "full_dequant_materialized": { "type": "boolean" },
    "workspace_bytes": { "type": "integer", "minimum": 0 },
    "workspace_peak_bytes": { "type": "integer", "minimum": 0 },
    "kernel_ms": { "type": "number", "minimum": 0 },
    "launch_ms": { "type": "number", "minimum": 0 },
    "sync_ms": { "type": "number", "minimum": 0 },
    "transfer_h2d_bytes": { "type": "integer", "minimum": 0 },
    "transfer_d2h_bytes": { "type": "integer", "minimum": 0 },
    "tensor_core_claimed": { "type": "boolean" },
    "tensor_core_used": { "type": "boolean" },
    "profiler_artifact_path": { "type": "string" },
    "profiler_artifact_sha256": { "type": "string" },
    "speedup_ratio": { "type": "number" },
    "compression_status": {
      "type": "string",
      "enum": ["none", "accounting-only", "reference", "experimental"]
    },
    "compression_profile_id": { "type": "string" },
    "quantization_scope": { "type": "string" },
    "algorithm_family": { "type": "string" },
    "payload_bits_per_value": { "type": "number", "minimum": 0 },
    "effective_bits_per_value": { "type": "number", "minimum": 0 },
    "metadata_bits_per_value": { "type": "number", "minimum": 0 },
    "key_quant_axis": { "type": "string" },
    "value_quant_axis": { "type": "string" },
    "pre_rope_or_post_rope": { "type": "string" },
    "group_size": { "type": "integer", "minimum": 0 },
    "residual_fp_window_tokens": { "type": "integer", "minimum": 0 },
    "outlier_policy": { "type": "string" },
    "rotation_policy": { "type": "string" },
    "rotation_seed": { "type": "integer", "minimum": 0 },
    "projection_policy": { "type": "string" },
    "qjl_residual_bits": { "type": "integer", "minimum": 0 },
    "dequant_workspace_peak_bytes": { "type": "integer", "minimum": 0 },
    "kv_payload_bytes": { "type": "integer", "minimum": 0 },
    "kv_metadata_bytes": { "type": "integer", "minimum": 0 },
    "kv_residual_or_sketch_bytes": { "type": "integer", "minimum": 0 },
    "compression_decode_overhead_ms": { "type": "number", "minimum": 0 },
    "attention_logit_error_p95": { "type": "number", "minimum": 0 },
    "attention_logit_error_p99": { "type": "number", "minimum": 0 },
    "attention_topk_overlap": { "type": "number", "minimum": 0, "maximum": 1 },
    "quality_gate_id": { "type": "string", "minLength": 1 },
    "quality_result_path": { "type": "string" },
    "cap_certification_status": {
      "type": "string",
      "enum": ["research-only", "measured-non-certified", "quality-gated", "validated-benchmark", "rejected"]
    },
    "claim_status": {
      "type": "string",
      "enum": ["measured", "measured-non-certified", "rejected", "research-only"]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "compression_status": {
            "enum": ["reference", "experimental"]
          }
        }
      },
      "then": {
        "required": [
          "effective_bits_per_value",
          "metadata_bits_per_value",
          "kv_payload_bytes",
          "kv_metadata_bytes",
          "compression_decode_overhead_ms",
          "quality_result_path"
        ]
      }
    }
  ],
  "additionalProperties": false
}
