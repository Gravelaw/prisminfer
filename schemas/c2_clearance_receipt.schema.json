{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prisminfer.local/schemas/c2_clearance_receipt.schema.json",
  "title": "PrismInfer synthetic C2 clearance candidate receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "receipt_class", "repository", "reviewed_sha",
    "source_tree_sha", "worker_sha256", "worker_approval_identity",
    "workflow_run_id", "authorization_id", "gpu_uuid", "case_name", "status", "failure_reason",
    "cleanup_status", "review_status", "claim_scope", "promotable",
    "c2_credit", "lease_id", "job_identity", "process_wddm_source",
    "last_good_stage",
    "terminal_trigger_canonical", "terminal_trigger_sha256",
    "last_good_sample_sha256", "pre_cleanup_evidence_sha256",
    "evidence_bundle_sha256", "adapter_luid_high", "adapter_luid_low",
    "adapter_index", "worker_timeout_milliseconds",
    "post_admission_payload_bytes", "maximum_payload_bytes",
    "context_cuda_free_bytes", "context_cuda_total_bytes",
    "last_heartbeat_cuda_free_bytes", "last_heartbeat_cuda_total_bytes",
    "pre_wddm_local_usage_bytes", "final_wddm_local_usage_bytes",
    "cleanup_wddm_positive_delta_bytes", "cleanup_wddm_tolerance_bytes",
    "last_sample_monotonic_milliseconds",
    "last_sample_wddm_local_budget_bytes", "last_sample_wddm_local_usage_bytes",
    "process_wddm_sample_monotonic_milliseconds",
    "process_wddm_current_bytes", "process_wddm_peak_bytes",
    "last_host_sample_monotonic_milliseconds",
    "last_host_memory_available_bytes", "last_host_commit_available_bytes",
    "last_thermal_sample_monotonic_milliseconds",
    "last_gpu_temperature_celsius", "last_gpu_slowdown_celsius",
    "pre_host_memory_available_bytes", "final_host_memory_available_bytes",
    "pre_host_commit_available_bytes", "final_host_commit_available_bytes",
    "pre_gpu_temperature_celsius", "final_gpu_temperature_celsius",
    "root_process_id",
    "heartbeat_count", "context_ready_observed", "token_consumed_observed",
    "worker_exit_observed", "job_tree_empty",
    "job_accounting_reconciled", "device_resources_reconciled",
    "artifact_handles_closed", "temporary_files_reconciled",
    "last_gpu_thermal_throttling", "last_gpu_power_brake_slowdown",
    "last_wddm_available", "last_process_wddm_available",
    "last_host_available", "last_thermal_available"
  ],
  "properties": {
    "schema_version": {"const": "prisminfer-c2-clearance-receipt-v1"},
    "receipt_class": {"const": "c2-clearance-candidate"},
    "repository": {"type": "string", "minLength": 1, "maxLength": 128},
    "reviewed_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "source_tree_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "worker_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "worker_approval_identity": {"type": "string", "minLength": 1, "maxLength": 128},
    "workflow_run_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "authorization_id": {"type": "string", "pattern": "^[A-Za-z0-9_.:-]{1,128}$"},
    "gpu_uuid": {"type": "string", "pattern": "^GPU-[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"},
    "case_name": {"enum": ["success", "post-context-telemetry-loss", "heartbeat-loss", "watchdog-cancel"]},
    "status": {"enum": ["candidate-complete", "rejected", "aborted"]},
    "failure_reason": {"type": "string", "maxLength": 256},
    "cleanup_status": {"enum": ["cleaned", "quarantined"]},
    "review_status": {"const": "pending-independent-review"},
    "claim_scope": {"const": "synthetic-c2-candidate-non-promotable"},
    "promotable": {"const": false},
    "c2_credit": {"const": false},
    "lease_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "job_identity": {"type": "string", "minLength": 1, "maxLength": 256},
    "process_wddm_source": {"type": "string", "minLength": 1, "maxLength": 64},
    "last_good_stage": {"enum": ["pre-context", "post-context", "watchdog"]},
    "terminal_trigger_canonical": {"type": "string", "minLength": 1, "maxLength": 2048},
    "terminal_trigger_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "last_good_sample_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "pre_cleanup_evidence_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "evidence_bundle_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "adapter_luid_high": {"type": "integer", "minimum": -2147483648, "maximum": 2147483647},
    "adapter_luid_low": {"type": "integer", "minimum": 0, "maximum": 4294967295},
    "adapter_index": {"type": "integer", "minimum": 0, "maximum": 63},
    "worker_timeout_milliseconds": {"type": "integer", "minimum": 1, "maximum": 60000},
    "post_admission_payload_bytes": {"type": "integer", "minimum": 0, "maximum": 67108864},
    "maximum_payload_bytes": {"const": 67108864},
    "context_cuda_free_bytes": {"type": "integer", "minimum": 0},
    "context_cuda_total_bytes": {"type": "integer", "minimum": 0},
    "last_heartbeat_cuda_free_bytes": {"type": "integer", "minimum": 0},
    "last_heartbeat_cuda_total_bytes": {"type": "integer", "minimum": 0},
    "pre_wddm_local_usage_bytes": {"type": "integer", "minimum": 0},
    "final_wddm_local_usage_bytes": {"type": "integer", "minimum": 0},
    "cleanup_wddm_positive_delta_bytes": {"type": "integer", "minimum": 0, "maximum": 16777216},
    "cleanup_wddm_tolerance_bytes": {"const": 16777216},
    "last_sample_monotonic_milliseconds": {"type": "integer", "minimum": 1},
    "last_sample_wddm_local_budget_bytes": {"type": "integer", "minimum": 1},
    "last_sample_wddm_local_usage_bytes": {"type": "integer", "minimum": 0},
    "process_wddm_sample_monotonic_milliseconds": {"type": "integer", "minimum": 0},
    "process_wddm_current_bytes": {"type": "integer", "minimum": 0},
    "process_wddm_peak_bytes": {"type": "integer", "minimum": 0},
    "last_host_sample_monotonic_milliseconds": {"type": "integer", "minimum": 1},
    "last_host_memory_available_bytes": {"type": "integer", "minimum": 1},
    "last_host_commit_available_bytes": {"type": "integer", "minimum": 1},
    "last_thermal_sample_monotonic_milliseconds": {"type": "integer", "minimum": 1},
    "last_gpu_temperature_celsius": {"type": "integer", "minimum": -273, "maximum": 1000},
    "last_gpu_slowdown_celsius": {"type": "integer", "minimum": -273, "maximum": 1000},
    "pre_host_memory_available_bytes": {"type": "integer", "minimum": 1},
    "final_host_memory_available_bytes": {"type": "integer", "minimum": 1},
    "pre_host_commit_available_bytes": {"type": "integer", "minimum": 1},
    "final_host_commit_available_bytes": {"type": "integer", "minimum": 1},
    "pre_gpu_temperature_celsius": {"type": "integer", "minimum": -273, "maximum": 1000},
    "final_gpu_temperature_celsius": {"type": "integer", "minimum": -273, "maximum": 1000},
    "root_process_id": {"type": "integer", "minimum": 0, "maximum": 4294967295},
    "heartbeat_count": {"type": "integer", "minimum": 0, "maximum": 1000},
    "context_ready_observed": {"type": "boolean"},
    "token_consumed_observed": {"type": "boolean"},
    "worker_exit_observed": {"type": "boolean"},
    "job_tree_empty": {"type": "boolean"},
    "job_accounting_reconciled": {"type": "boolean"},
    "device_resources_reconciled": {"type": "boolean"},
    "artifact_handles_closed": {"type": "boolean"},
    "temporary_files_reconciled": {"type": "boolean"},
    "last_gpu_thermal_throttling": {"type": "boolean"},
    "last_gpu_power_brake_slowdown": {"type": "boolean"},
    "last_wddm_available": {"type": "boolean"},
    "last_process_wddm_available": {"type": "boolean"},
    "last_host_available": {"type": "boolean"},
    "last_thermal_available": {"type": "boolean"}
  }
}
